# ========================================
# REQUIRED CONFIGURATION
# ========================================

# Telegram Bot Token
# Get this from @BotFather on Telegram
# Example: 1234567890:ABCdefGHIjklMNOpqrsTUVwxyz
BOT_TOKEN=your_telegram_bot_token_here

# YesScale API Key
# Get this from https://yescale.io/ (Dashboard -> API Keys)
# Example: sk-abc123...
YESCALE_API_KEY=your_yescale_api_key_here

# ========================================
# OPTIONAL CONFIGURATION
# ========================================

# Environment (development | production | test)
NODE_ENV=development

# Logging Configuration
# Levels: error | warn | info | http | verbose | debug | silly
LOG_LEVEL=info

# Session Configuration
# Session timeout in milliseconds (default: 1 hour = 3600000ms)
SESSION_TIMEOUT=3600000

# Maximum conversation history length per user
MAX_HISTORY_LENGTH=20

# File Handling Configuration
# Maximum number of files per user
MAX_FILES_PER_USER=10

# Maximum file size in MB
MAX_FILE_SIZE_MB=20

# File storage path (where uploaded files are stored)
FILE_STORAGE_PATH=./uploads

# Rate Limiting Configuration
# Maximum text messages per minute per user
RATE_LIMIT_MESSAGES=20

# Maximum image messages per minute per user
RATE_LIMIT_IMAGES=5

# Redis Configuration (Optional - for production)
# If not provided, in-memory storage will be used
# Example: redis://localhost:6379
# REDIS_URL=redis://localhost:6379
# REDIS_PASSWORD=your_redis_password

# YesScale Model Configuration
# API Base URL (default: https://api.yescale.io/v1)
YESCALE_BASE_URL=https://api.yescale.io/v1

# Text model name (default: gpt-4o)
# Other options: gpt-3.5-turbo, gpt-4, gpt-4-turbo, claude-3-opus, gemini-pro, etc.
YESCALE_TEXT_MODEL=gpt-4o

# Vision model name (default: gpt-4o)
# Vision-capable models: gpt-4o, gpt-4-turbo, claude-3-opus, gemini-pro-vision
YESCALE_VISION_MODEL=gpt-4o

# Temperature for generation (0.0 to 2.0)
YESCALE_TEMPERATURE=0.7

# Maximum output tokens
YESCALE_MAX_TOKENS=2048

# Top P sampling parameter (0.0 to 1.0)
YESCALE_TOP_P=0.95

# Request timeout in milliseconds (default: 60000ms = 60s)
YESCALE_TIMEOUT=60000

# Bot Configuration
# Maximum message length (Telegram limit is 4096)
MAX_MESSAGE_LENGTH=4096

# Enable/disable typing indicator
SHOW_TYPING_INDICATOR=true

# Bot timezone (for logging timestamps)
TZ=UTC
