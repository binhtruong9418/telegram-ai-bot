# ========================================
# REQUIRED CONFIGURATION
# ========================================

# Telegram Bot Token — get from @BotFather
BOT_TOKEN=your_telegram_bot_token_here

# OpenRouter API Key — get from https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here

# ========================================
# OPTIONAL CONFIGURATION
# ========================================

# Environment (development | production | test)
NODE_ENV=development

# Logging level (error | warn | info | http | verbose | debug | silly)
LOG_LEVEL=info

# Session timeout in milliseconds (default: 1 hour)
SESSION_TIMEOUT=3600000

# Maximum conversation history length per user
MAX_HISTORY_LENGTH=20

# File handling
MAX_FILES_PER_USER=10
MAX_FILE_SIZE_MB=20
FILE_STORAGE_PATH=./uploads

# Rate limiting (per minute per user)
RATE_LIMIT_MESSAGES=20
RATE_LIMIT_IMAGES=5

# Redis (optional — uses in-memory storage if not set)
# REDIS_URL=redis://localhost:6379
# REDIS_PASSWORD=your_redis_password

# ========================================
# OPENROUTER MODEL CONFIGURATION
# ========================================

# Free models (append :free suffix):
#   meta-llama/llama-3.3-70b-instruct:free  — strong general-purpose LLM
#   google/gemma-3-27b-it:free              — vision-capable
#   deepseek/deepseek-chat:free
#   qwen/qwen3-235b-a22b:free
#
# Paid models (no suffix):
#   openai/gpt-4o
#   anthropic/claude-3.5-sonnet
#   google/gemini-2.5-flash
#
# Full list: https://openrouter.ai/models

OPENROUTER_TEXT_MODEL=meta-llama/llama-3.3-70b-instruct:free
OPENROUTER_VISION_MODEL=google/gemma-3-27b-it:free
OPENROUTER_TEMPERATURE=0.7
OPENROUTER_MAX_TOKENS=2048
OPENROUTER_TOP_P=0.95
OPENROUTER_TIMEOUT=60000

# Optional: identify your app in OpenRouter rankings/usage
# OPENROUTER_APP_URL=https://your-app.com
# OPENROUTER_APP_TITLE=My Telegram Bot

# ========================================
# BOT SETTINGS
# ========================================

# Maximum message length (Telegram limit: 4096)
MAX_MESSAGE_LENGTH=4096

# Show typing indicator while processing
SHOW_TYPING_INDICATOR=true

# Timezone for logging timestamps
TZ=UTC
