# ========================================
# YESCALE AI TELEGRAM BOT - QUICK START
# ========================================

# 1. Get Telegram Bot Token from @BotFather
BOT_TOKEN=

# 2. Get YesScale API Key from https://yescale.io/
#    - Register for free ($1 credit included)
#    - Go to Dashboard → API Keys
#    - Create new API key
YESCALE_API_KEY=

# ========================================
# OPTIONAL: AI MODEL CONFIGURATION
# ========================================

# Choose your AI model (default: gpt-4o)
# Options:
#   - gpt-4o (recommended - best balance of speed/quality/cost)
#   - gpt-4-turbo
#   - gpt-3.5-turbo (fastest, cheapest)
#   - claude-3-opus (highest quality)
#   - claude-3-sonnet
#   - gemini-2.5-flash
#   - deepseek-chat
# YESCALE_TEXT_MODEL=gpt-4o
# YESCALE_VISION_MODEL=gpt-4o

# Temperature (0.0-2.0, default: 0.7)
# Lower = more focused, Higher = more creative
# YESCALE_TEMPERATURE=0.7

# Max tokens per response (default: 2048)
# YESCALE_MAX_TOKENS=2048

# ========================================
# OPTIONAL: BOT CONFIGURATION
# ========================================

# Environment
# NODE_ENV=production

# Logging level (error | warn | info | debug)
# LOG_LEVEL=info

# Rate limiting (messages per minute)
# RATE_LIMIT_MESSAGES=20
# RATE_LIMIT_IMAGES=5

# ========================================
# That's it! Run: npm install && npm start
# ========================================
